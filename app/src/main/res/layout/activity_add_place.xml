<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="44dp"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:src="@drawable/ic_arrow_left"
            android:padding="8dp"
            android:tint="@color/foreground"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_new_place"
            android:textColor="@color/primary_foreground"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_bold"/>

    </LinearLayout>

    <!-- Scrollable Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Photo upload area -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/photos_label"
                android:textColor="@color/foreground"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/btn_upload_gallery"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_upload_dashed"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_upload" android:tint="@color/muted_foreground"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="@string/upload_label"
                        android:textColor="@color/muted_foreground" android:textSize="10sp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_open_camera"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_upload_dashed"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/ic_camera" android:tint="@color/muted_foreground"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="@string/camera_label"
                        android:textColor="@color/muted_foreground" android:textSize="10sp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>

                <!-- Preview image thumbnail -->
                <ImageView
                    android:id="@+id/iv_preview"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginStart="12dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:background="@drawable/bg_card_rounded"/>

            </LinearLayout>

            <!-- Place Name -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/place_name_label" android:textColor="@color/foreground"
                android:textSize="12sp" android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_place_name"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="@string/place_name_hint" android:textSize="13sp"
                    android:fontFamily="@font/inter" android:inputType="textCapWords"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category Spinner -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/category_label" android:textColor="@color/foreground"
                android:textSize="12sp" android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="6dp"/>
            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:background="@drawable/bg_card_rounded"
                android:paddingLeft="12dp" android:paddingRight="12dp"
                android:layout_marginBottom="16dp" android:fontFamily="@font/inter"/>

            <!-- City -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/city_label" android:textColor="@color/foreground"
                android:textSize="12sp" android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_city"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="@string/city_hint" android:textSize="13sp"
                    android:fontFamily="@font/inter" android:inputType="textCapWords"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Address -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/address_label" android:textColor="@color/foreground"
                android:textSize="12sp" android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_address"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="@string/address_hint" android:textSize="13sp"
                    android:fontFamily="@font/inter"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone (optional) -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/phone_label" android:textColor="@color/foreground"
                android:textSize="12sp" android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="@string/phone_hint" android:textSize="13sp"
                    android:fontFamily="@font/inter" android:inputType="phone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/description_label" android:textColor="@color/foreground"
                android:textSize="12sp" android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent" android:layout_height="120dp"
                    android:hint="@string/description_hint" android:textSize="13sp"
                    android:fontFamily="@font/inter" android:inputType="textMultiLine"
                    android:gravity="top" android:minLines="4"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/submit_btn"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold"
                android:backgroundTint="@color/primary"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
