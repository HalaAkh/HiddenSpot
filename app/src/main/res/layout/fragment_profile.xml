<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Primary Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_primary"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="44dp"
            android:paddingBottom="32dp">

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/my_profile"
                    android:textColor="@color/primary_foreground"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold"/>

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/foreground"
                    android:padding="8dp"/>

            </LinearLayout>

            <!-- User info row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@color/primary_dark"/>

                    <TextView
                        android:id="@+id/tv_avatar_letter"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:gravity="center"
                        android:text=""
                        android:textColor="@color/primary_foreground"
                        android:textSize="32sp"
                        android:fontFamily="@font/poppins_bold"
                        android:background="@color/primary_dark"/>

                    <ImageButton
                        android:id="@+id/btn_change_photo"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:src="@drawable/ic_camera"
                        android:padding="6dp"
                        android:background="@drawable/bg_chip_active"
                        android:tint="@color/primary_foreground"/>

                </FrameLayout>

                <!-- Name + stats -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/primary_foreground"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:id="@+id/tv_bio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text=""
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_posts_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/primary_foreground"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_favorites_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text=""
                            android:textColor="@color/primary_foreground"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Stats Card (overlapping header) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Places stat -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_map_pin" android:tint="@color/secondary"/>
                    <TextView android:id="@+id/tv_stat_places"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="0"
                        android:textColor="@color/foreground" android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/posts_label" android:textColor="@color/muted_foreground"
                        android:textSize="10sp" android:fontFamily="@font/inter"/>
                </LinearLayout>

                <!-- Likes stat -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_heart_filled"/>
                    <TextView android:id="@+id/tv_stat_likes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="0"
                        android:textColor="@color/foreground" android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/likes_label" android:textColor="@color/muted_foreground"
                        android:textSize="10sp" android:fontFamily="@font/inter"/>
                </LinearLayout>

                <!-- Avg rating stat -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_star_filled"/>
                    <TextView android:id="@+id/tv_stat_rating"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="—"
                        android:textColor="@color/foreground" android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/avg_rating_label" android:textColor="@color/muted_foreground"
                        android:textSize="10sp" android:fontFamily="@font/inter"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Menu Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include layout="@layout/item_profile_menu_row"
                    android:id="@+id/row_edit_profile"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                <include layout="@layout/item_profile_menu_row"
                    android:id="@+id/row_ratings"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                <include layout="@layout/item_profile_menu_row"
                    android:id="@+id/row_notifications"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                <include layout="@layout/item_profile_menu_row"
                    android:id="@+id/row_help"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- My Posts Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="12dp"
            android:text="@string/my_posts"
            android:textColor="@color/foreground"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_my_posts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"/>

        <!-- Sign Out Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.HiddenSpot.Button.Destructive"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:text="@string/sign_out"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/destructive"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
