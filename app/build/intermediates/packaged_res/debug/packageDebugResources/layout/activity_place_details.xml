<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">
        <!--  ── Hero Image ─────────────────────────────────────────────────  -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <ImageView
                android:id="@+id/iv_hero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@color/muted" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_image_overlay" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingTop="44dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_white"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_left"
                    android:tint="@color/foreground" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_circle_white"
                    android:padding="8dp"
                    android:src="@drawable/ic_share"
                    android:tint="@color/foreground" />

                <ImageButton
                    android:id="@+id/btn_favorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_white"
                    android:padding="8dp"
                    android:src="@drawable/ic_heart" />
            </LinearLayout>

            <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                android:id="@+id/dots_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                app:dotsColor="@color/primary_foreground"
                app:dotsSize="6dp"
                app:dotsSpacing="4dp"
                app:selectedDotColor="@color/primary_foreground" />
        </FrameLayout>
        <!--  ── Main Info Card ──────────────────────────────────────────────  -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="-24dp"
            android:layout_marginRight="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <!--  Category + Rating  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_category_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_active"
                        android:fontFamily="@font/poppins_semibold"
                        android:paddingLeft="10dp"
                        android:paddingTop="4dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="4dp"
                        android:textColor="@color/primary_foreground"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/surface_warm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="10dp"
                        android:paddingTop="6dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="6dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star_filled" />

                        <TextView
                            android:id="@+id/tv_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/foreground"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
                <!--  Place Name  -->
                <TextView
                    android:id="@+id/tv_place_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/foreground"
                    android:textSize="20sp" />
                <!--  Address  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_map_pin"
                        android:tint="@color/muted_foreground" />

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp" />
                </LinearLayout>
                <!--  Phone  -->
                <LinearLayout
                    android:id="@+id/layout_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_phone"
                        android:tint="@color/muted_foreground" />

                    <TextView
                        android:id="@+id/tv_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <!--  Description  -->
                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/inter"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="@color/foreground"
                    android:textSize="13sp" />
                <!--  Divider  -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/border_color" />
                <!--  Vote Buttons  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_upvote"
                        style="@style/Widget.HiddenSpot.Button.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="0"
                        android:textColor="@color/muted_foreground"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_thumbs_up"
                        app:iconTint="@color/muted_foreground" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_downvote"
                        style="@style/Widget.HiddenSpot.Button.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="0"
                        android:textColor="@color/muted_foreground"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_thumbs_down"
                        app:iconTint="@color/muted_foreground" />
                </LinearLayout>
                <!--  Action Buttons  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_maps"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/secondary"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="@string/open_in_maps"
                        android:textSize="12sp"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_navigation"
                        app:iconTint="@color/primary_foreground" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_call"
                        style="@style/Widget.HiddenSpot.Button.Outline"
                        android:layout_width="48dp"
                        android:layout_height="44dp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_phone"
                        app:iconTint="@color/foreground" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  ── Map Preview Card (NEW) ───────────────────────────────────────  -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="📍 Location"
                    android:textColor="@color/foreground"
                    android:textSize="14sp" />
                <!--  Tappable map placeholder that opens MapActivity  -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_map_view"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:backgroundTint="@color/muted"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="🗺️ Open Map View"
                    android:textColor="@color/foreground"
                    android:textSize="14sp"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  ── Posted By Card ───────────────────────────────────────────────  -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp">

                    <TextView
                        android:id="@+id/tv_poster_initial"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@color/surface_warm"
                        android:fontFamily="@font/poppins_bold"
                        android:gravity="center"
                        android:textColor="@color/primary"
                        android:textSize="16sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_poster_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/foreground"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_posted_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/muted_foreground"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  ── Reviews Card (NEW) ──────────────────────────────────────────  -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <!--  Section header  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="⭐ Reviews"
                        android:textColor="@color/foreground"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tv_review_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp" />
                </LinearLayout>
                <!--  Write a review: stars input  -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/inter"
                    android:text="Rate this place:"
                    android:textColor="@color/muted_foreground"
                    android:textSize="12sp" />

                <RatingBar
                    android:id="@+id/rating_bar_input"
                    style="?android:attr/ratingBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:numStars="5"
                    android:progressTint="@color/star_color"
                    android:rating="0"
                    android:secondaryProgressTint="@color/star_color"
                    android:stepSize="1" />
                <!--  Comment input  -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.HiddenSpot.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Write a comment (optional)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_review_comment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="5"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>
                <!--  Submit button  -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_review"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Submit Review"
                    android:textSize="13sp"
                    app:cornerRadius="12dp" />
                <!--  Divider  -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/border_color" />
                <!--  "No reviews yet" placeholder  -->
                <TextView
                    android:id="@+id/tv_no_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:text="No reviews yet. Be the first to review!"
                    android:textColor="@color/muted_foreground"
                    android:textSize="13sp"
                    android:visibility="gone" />
                <!--  Reviews list  -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>