<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── Profile header ──────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp">

            <!-- Avatar container (tappable) — shows either letter or photo -->
            <FrameLayout
                android:id="@+id/avatar_container"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <!-- Default: letter circle -->
                <TextView
                    android:id="@+id/tv_avatar_letter"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@color/surface_warm"
                    android:gravity="center"
                    android:textColor="@color/primary"
                    android:textSize="32sp"
                    android:fontFamily="@font/poppins_bold"/>

                <!-- Photo avatar (hidden until a photo is uploaded) -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:visibility="gone"
                    app:civ_border_width="2dp"
                    app:civ_border_color="@color/primary"/>

                <!-- Camera icon overlay (bottom-right) -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_camera"
                    android:padding="4dp"
                    android:tint="@color/foreground"/>

            </FrameLayout>

            <!-- Username -->
            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/foreground"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"/>

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/discovering_since"
                android:textColor="@color/muted_foreground"
                android:textSize="12sp"
                android:fontFamily="@font/inter"/>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@color/surface_warm"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Places -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_places"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/foreground"
                        android:textSize="18sp" android:fontFamily="@font/poppins_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/posts_label" android:textColor="@color/muted_foreground"
                        android:textSize="11sp" android:fontFamily="@font/inter"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp"
                    android:background="@color/border_color"/>

                <!-- Likes -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_likes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/foreground"
                        android:textSize="18sp" android:fontFamily="@font/poppins_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/likes_label" android:textColor="@color/muted_foreground"
                        android:textSize="11sp" android:fontFamily="@font/inter"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp"
                    android:background="@color/border_color"/>

                <!-- Avg Rating -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_stat_rating"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/foreground"
                        android:textSize="18sp" android:fontFamily="@font/poppins_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/avg_rating_label"
                        android:textColor="@color/muted_foreground"
                        android:textSize="11sp" android:fontFamily="@font/inter"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Menu rows ───────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout android:id="@+id/row_edit_profile"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <TextView android:id="@+id/tv_edit_icon"
                        android:layout_width="24dp" android:layout_height="wrap_content"
                        android:textSize="16sp" android:gravity="center"/>
                    <TextView android:id="@+id/tv_edit_label"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:textColor="@color/foreground" android:textSize="14sp"
                        android:fontFamily="@font/inter"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right" android:tint="@color/muted_foreground"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border_color" android:layout_marginStart="52dp"/>

                <LinearLayout android:id="@+id/row_ratings"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <TextView android:id="@+id/tv_ratings_icon"
                        android:layout_width="24dp" android:layout_height="wrap_content"
                        android:textSize="16sp" android:gravity="center"/>
                    <TextView android:id="@+id/tv_ratings_label"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:textColor="@color/foreground" android:textSize="14sp"
                        android:fontFamily="@font/inter"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right" android:tint="@color/muted_foreground"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border_color" android:layout_marginStart="52dp"/>

                <LinearLayout android:id="@+id/row_notifications"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <TextView android:id="@+id/tv_notif_icon"
                        android:layout_width="24dp" android:layout_height="wrap_content"
                        android:textSize="16sp" android:gravity="center"/>
                    <TextView android:id="@+id/tv_notif_label"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:textColor="@color/foreground" android:textSize="14sp"
                        android:fontFamily="@font/inter"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right" android:tint="@color/muted_foreground"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border_color" android:layout_marginStart="52dp"/>

                <LinearLayout android:id="@+id/row_help"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <TextView android:id="@+id/tv_help_icon"
                        android:layout_width="24dp" android:layout_height="wrap_content"
                        android:textSize="16sp" android:gravity="center"/>
                    <TextView android:id="@+id/tv_help_label"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:textColor="@color/foreground" android:textSize="14sp"
                        android:fontFamily="@font/inter"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right" android:tint="@color/muted_foreground"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── My Posts ────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/my_posts"
                    android:textColor="@color/foreground"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"/>
                <TextView android:id="@+id/tv_posts_count"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/muted_foreground"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_my_posts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>

        <!-- ── Logout ──────────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.HiddenSpot.Button.Destructive"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="24dp"
            android:text="@string/sign_out"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/destructive"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>